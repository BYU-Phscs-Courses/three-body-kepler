 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"x3sol", "-", "x2sol"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "400"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"y3sol", "-", "y2sol"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "400"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.985450144893224*^9, 3.985450155387886*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"c4a91cf1-e6c0-4edb-8fe5-b478c3fbeeb4"],

