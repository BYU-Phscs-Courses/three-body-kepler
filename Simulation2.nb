Now let\[CloseCurlyQuote]s graph Earth\[CloseCurlyQuote]s calculated orbit \
alongside its predicted orbit.\
\>", "Text",
 CellChangeTimes->{{3.9854506756953793`*^9, 
  3.985450694599266*^9}},ExpressionUUID->"37f4d8ca-03c8-4d18-ba91-\
fca509779f13"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f2", "=", 
   RowBox[{"1", "/", "T2"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x2sol", ",", 
     RowBox[{
      RowBox[{"Norm", "[", "r2i", "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "*", "Pi", "*", "f2", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "400"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"y2sol", ",", 
     RowBox[{
      RowBox[{"Norm", "[", "r2i", "]"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "*", "Pi", "*", "f2", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "400"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
