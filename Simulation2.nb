Cell[CellGroupData[{

Cell["Part 7 - Double-Checking the Results", "Section",
 CellChangeTimes->{{3.985450274775401*^9, 
  3.985450276788121*^9}},ExpressionUUID->"356733b0-62ee-45ca-92ae-\
49a2a27b7f3e"],

Cell["\<\
Like we did in the last simulation with the hypothetical planet and its \
hypothetical moon, we\[CloseCurlyQuote]ll find the orbital periods of Earth \
and the Moon and compare the resulting trigonometric functions to the \
generated motion from the differential equations. Let\[CloseCurlyQuote]s \
first compute the orbital periods of both bodies (remember, they are measured \
in days):\
\>", "Text",
 CellChangeTimes->{{3.985450288372306*^9, 3.985450308464657*^9}, {
  3.985450479903275*^9, 3.985450530456497*^9}, {3.985450662359384*^9, 
  3.985450671645975*^9}, {3.985450763018403*^9, 
  3.985450791709375*^9}},ExpressionUUID->"1fbb583b-0731-4f00-b74e-\
c1931d059b64"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"T2", "=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"4", "*", 
    RowBox[{"Pi", "^", "2"}], "*", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Norm", "[", "r2i", "]"}], ")"}], "^", "3"}], "/", 
     RowBox[{"(", 
      RowBox[{"G", "*", 
       RowBox[{"(", 
        RowBox[{"m1", "+", "m2"}], ")"}]}], ")"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"T3", "=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"4", "*", 
    RowBox[{"Pi", "^", "2"}], "*", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Norm", "[", "r3i", "]"}], ")"}], "^", "3"}], "/", 
     RowBox[{"(", 
