Cell["\<\
Like with the last simulation in which the moon\[CloseCurlyQuote]s orbital \
period had a greater error than the planet, the orbital period of Earth\
\[CloseCurlyQuote]s Moon has a greater error in this simulation than that of \
Earth itself. Also, let\[CloseCurlyQuote]s find the percent error of the \
orbital periods of Earth and the Moon comparing what we predicted to the \
actual values in real life. We\[CloseCurlyQuote]ll measure the errors in \
percentage from the real-life values.\
\>", "Text",
 CellChangeTimes->{{3.985450748647616*^9, 3.985450757111966*^9}, {
  3.9854508008452473`*^9, 3.9854508848368673`*^9}, {3.985450987499337*^9, 
  3.985451015487714*^9}},ExpressionUUID->"9e0e02a4-ddc5-42de-bd19-\
a1d25fde431d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"T2Real", "=", "365.256363004"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T3Real", "=", "27.321661"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Error2", "=", 
  RowBox[{"100", "*", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"T2Real", "-", "T2"}], "]"}], "/", "T2Real"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Error3", "=", 
  RowBox[{"100", "*", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"T3Real", "-", "T3"}], "]"}], "/", "T3Real"}]}]}]}], "Input",
 CellChangeTimes->{{3.98545088924181*^9, 3.985450896244463*^9}, {
  3.985450952651634*^9, 3.985450983369521*^9}, {3.985451031524372*^9, 
  3.985451063284627*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"6dde857f-5eb0-4ff6-aceb-7787836840b2"],

