Cell[CellGroupData[{

Cell["Part 5 - Solving the Differential Equation", "Section",
 CellChangeTimes->{
  3.985449830759197*^9, {3.985449894110811*^9, 
   3.985449894394024*^9}},ExpressionUUID->"fd669e29-7645-4e89-bfa7-\
a05ac17ac42e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"solution", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x1", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc1", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y1", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc1", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x2", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc2", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y2", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc2", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x3", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc3", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y3", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc3", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x1", "[", "0", "]"}], "==", 
         RowBox[{"r1i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y1", "[", "0", "]"}], "==", 
         RowBox[{"r1i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x2", "[", "0", "]"}], "==", 
         RowBox[{"r2i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y2", "[", "0", "]"}], "==", 
         RowBox[{"r2i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x3", "[", "0", "]"}], "==", 
         RowBox[{
          RowBox[{"r2i", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{"r3i", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"y3", "[", "0", "]"}], "==", 
         RowBox[{
          RowBox[{"r2i", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "+", 
          RowBox[{"r3i", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x1", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v1i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y1", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v1i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x2", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v2i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y2", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v2i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x3", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v3i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y3", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v3i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x1", "[", "t", "]"}], ",", 
        RowBox[{"y1", "[", "t", "]"}], ",", 
        RowBox[{"x2", "[", "t", "]"}], ",", 
        RowBox[{"y2", "[", "t", "]"}], ",", 
        RowBox[{"x3", "[", "t", "]"}], ",", 
        RowBox[{"y3", "[", "t", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x1sol", "=", 
   RowBox[{
    RowBox[{"x1", "[", "t", "]"}], "/.", 
    RowBox[{"solution", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y1sol", "=", 
    RowBox[{
     RowBox[{"y1", "[", "t", "]"}], "/.", 
     RowBox[{"solution", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x2sol", "=", 
   RowBox[{
    RowBox[{"x2", "[", "t", "]"}], "/.", 
    RowBox[{"solution", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y2sol", "=", 
    RowBox[{
     RowBox[{"y2", "[", "t", "]"}], "/.", 
     RowBox[{"solution", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x3sol", "=", 
   RowBox[{
    RowBox[{"x3", "[", "t", "]"}], "/.", 
    RowBox[{"solution", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y3sol", "=", 
   RowBox[{
    RowBox[{"y3", "[", "t", "]"}], "/.", 
    RowBox[{"solution", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.985450025724372*^9, 3.9854500269573936`*^9}, {
  3.9854500683925753`*^9, 3.985450069062286*^9}},
