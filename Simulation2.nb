Cell["\<\
Now let\[CloseCurlyQuote]s do the same with the orbital motion of the Moon \
with respect to Earth:\
\>", "Text",
 CellChangeTimes->{{3.9854505888935537`*^9, 
  3.985450598752602*^9}},ExpressionUUID->"fe5ae9cb-5fff-4f6b-9037-\
ed3b1e3c4598"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f3", "=", 
   RowBox[{"1", "/", "T3"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x3sol", "-", "x2sol"}], ",", 
     RowBox[{
      RowBox[{"Norm", "[", "r3i", "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "*", "Pi", "*", "f3", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "40"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"y3sol", "-", "y2sol"}], ",", 
     RowBox[{
      RowBox[{"Norm", "[", "r3i", "]"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "*", "Pi", "*", "f3", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "40"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.985450609544866*^9, 3.985450642138524*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"9a354697-2139-4050-b6de-d7356a410632"],

