Cell[BoxData[
 RowBox[{
  RowBox[{"orbit", "[", 
   RowBox[{"tmax_", ",", "increment_", ",", "pause_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", "=", "0."}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"t", "<=", "tmax"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"t", "+=", "increment"}], ";", "\[IndentingNewLine]", 
        RowBox[{"EarthPoint", "=", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{"a", "*", "t"}], "]"}], ",", 
            RowBox[{"Sin", "[", 
             RowBox[{"b", "*", "t"}], "]"}]}], "}"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"EarthLine", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", 
             RowBox[{"a", "*", "t"}], "]"}], ",", 
            RowBox[{"Sin", "[", 
             RowBox[{"b", "*", "t"}], "]"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Pause", "[", "pause", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"SunPoint", "=", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"EarthLine", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"EarthPoint", "=", 
      RowBox[{"{", "initial", "}"}]}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.985121275422721*^9, 3.9851212814833193`*^9}, {
