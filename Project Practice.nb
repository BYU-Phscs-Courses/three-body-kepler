Cell[BoxData[
 RowBox[{
  RowBox[{"update", "[", 
   RowBox[{
   "max_", ",", "function_", ",", "variable_", ",", "increment_", ",", 
    "pause_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", "=", "0.0"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"x", "<=", "max"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"lastPoint", "=", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"function", "/.", 
             RowBox[{"variable", "->", "x"}]}]}], "}"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"points", ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", 
            RowBox[{"function", "/.", 
             RowBox[{"variable", "->", "x"}]}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"x", "=", 
         RowBox[{"x", "+", "increment"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Pause", "[", "pause", "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"points", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"lastPoint", "=", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], "}"}]}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
