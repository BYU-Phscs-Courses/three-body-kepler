Cell[CellGroupData[{

Cell["Part 6 - Double-Checking the Results", "Section",
 CellChangeTimes->{{3.985446093144771*^9, 3.985446100254076*^9}, {
  3.985446301376007*^9, 
  3.9854463023333282`*^9}},ExpressionUUID->"867ec0b7-8ce7-470e-a452-\
f2ea205196d0"],

Cell["\<\
Let\[CloseCurlyQuote]s use Newton\[CloseCurlyQuote]s version of Kepler\
\[CloseCurlyQuote]s 3rd law of planetary motion to predict the orbital \
periods of the planet and the moon around the star as T1 and T2, \
respectively. The star doesn\[CloseCurlyQuote]t move very much and its \
distance from the origin is always negligible as we saw in the graph of its \
motion. This formula describing the orbital motion of celestial bodies is \
shown down below:\
\>", "Text",
 CellChangeTimes->{{3.985446146439559*^9, 3.985446209813908*^9}, {
  3.9854462444303083`*^9, 3.985446244703991*^9}, {3.985446289283345*^9, 
  3.985446298530089*^9}, {3.9854463882815113`*^9, 3.9854464525245333`*^9}, {
  3.985446592674315*^9, 
  3.9854466084669447`*^9}},ExpressionUUID->"5c484271-621e-4f64-9bb0-\
