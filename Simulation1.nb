Cell["\<\
Now we can test these by making certain trig-derived functions based on these \
orbital periods and comparing them to the actual motions of the planet and \
moon. Let\[CloseCurlyQuote]s start off with the orbital motion of the planet \
around the star.\
\>", "Text",
 CellChangeTimes->{{3.9854466320171337`*^9, 3.9854467342997293`*^9}, {
  3.9854467683255577`*^9, 3.98544680703157*^9}, {3.985446934315793*^9, 
  3.985446940119787*^9}, {3.9854471703986387`*^9, 3.985447171451085*^9}, {
  3.985447266152638*^9, 
  3.985447287859989*^9}},ExpressionUUID->"acae24d3-8f6f-441c-8e09-\
7ba8cc5da04e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f2", "=", 
   RowBox[{"1", "/", "T2"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x2sol", ",", 
     RowBox[{"50", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "*", "Pi", "*", "f2", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "40"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"y2sol", ",", 
     RowBox[{"50", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "*", "Pi", "*", "f2", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "40"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.98544681738967*^9, 3.985446889704431*^9}, {
  3.985446945485457*^9, 3.985446945665773*^9}, {3.985447257243042*^9, 
  3.985447258159649*^9}, {3.985447290932803*^9, 3.9854472968848543`*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"6a25d0d4-5bda-4744-b6fa-93673672c542"],

