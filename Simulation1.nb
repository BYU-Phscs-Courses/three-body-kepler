Cell["\<\
Because they moon\[CloseCurlyQuote]s orbit is so much faster than the planet, \
let\[CloseCurlyQuote]s limit the time range a bit on these graphs to get a \
better look at the moon\[CloseCurlyQuote]s orbit.\
\>", "Text",
 CellChangeTimes->{{3.985446028162861*^9, 
  3.9854460802096243`*^9}},ExpressionUUID->"2c0faed9-6617-4c1a-bd58-\
b4b73245c48d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"x3sol", "-", "x2sol"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{
   "PlotLabel", 
    "->", "\"\<Moon Motion in the x direction, Relative to Planet\>\""}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"y3sol", "-", "y2sol"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
