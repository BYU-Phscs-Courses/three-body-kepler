  RowBox[{"(*", 
   RowBox[{
   "r2", " ", "being", " ", "a", " ", "vector", " ", "representing", " ", 
    "the", " ", "position", " ", "of", " ", "the", " ", "planet", " ", 
    "relative", " ", "to", " ", "the", " ", "same", " ", "zero"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"r3", "[", "t_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x3", "[", "t", "]"}], ",", 
     RowBox[{"y3", "[", "t", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "r3", " ", "being", " ", "a", " ", "vector", " ", "representing", " ", 
