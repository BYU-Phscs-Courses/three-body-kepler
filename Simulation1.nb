Cell["\<\
Now let\[CloseCurlyQuote]s define the differential equations based on both \
Newtonian mechanics and Kepler\[CloseCurlyQuote]s laws of planetary motion.\
\>", "Text",
 CellChangeTimes->{{3.985096864418317*^9, 
  3.985096911769046*^9}},ExpressionUUID->"23fb1e19-7849-404f-a3c5-\
21a8c3d4896e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"r1", "[", "t_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x1", "[", "t", "]"}], ",", 
     RowBox[{"y1", "[", "t", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "r1", " ", "being", " ", "a", " ", "vector", " ", "representing", " ", 
    "the", " ", "position", " ", "of", " ", "the", " ", "star", " ", 
    "relative", " ", "to", " ", "our", " ", "zero", " ", 
    RowBox[{"(", 
     RowBox[{"which", " ", "was", " ", "the", " ", 
      RowBox[{"star", "'"}], "s", " ", "initial", " ", "position"}], ")"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
