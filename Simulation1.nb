Cell["\<\
The computational error of the moon\[CloseCurlyQuote]s orbital period seems \
to be greater than that of the planet\[CloseCurlyQuote]s orbital period. But \
either way, these equations do seem pretty useful for predicting the motions \
of moons in orbit around planets which are, in turn, in orbit around stars.\
\>", "Text",
 CellChangeTimes->{{3.985447330943697*^9, 
  3.985447428471593*^9}},ExpressionUUID->"252540ef-c756-45bb-85ae-\
045e63efdaef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Part 7 - Resulting Equation", "Section",
 CellChangeTimes->{{3.9854474817014227`*^9, 
  3.985447498834977*^9}},ExpressionUUID->"0d1bc275-6dd2-4cd0-9c5b-\
bf4f3b747023"],

Cell["\<\
Here are the equations of the planet\[CloseCurlyQuote]s x- and y-coordinates \
(with the star at the center of the orbit):\
\>", "Text",
 CellChangeTimes->{{3.985447545524*^9, 
  3.985447582346176*^9}},ExpressionUUID->"87bb3754-58b7-4441-aa03-\
00ff0ae8efa3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x2", "[", "t_", "]"}], "=", 
  RowBox[{"50", "*", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", "*", "Pi", "*", "f2", "*", "t"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y2", "[", "t_", "]"}], "=", 
  RowBox[{"50", "*", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "*", "Pi", "*", "f2", "*", "t"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.985447589949892*^9, 3.985447619956107*^9}, {
  3.9854476980992126`*^9, 3.9854476989631653`*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"a96442fa-e0b0-45db-9189-7b928fad6dff"],

Cell[BoxData[
 RowBox[{"50", " ", 
  RowBox[{"Cos", "[", 
   RowBox[{"0.2000001999999`", " ", "t"}], "]"}]}]], "Output",
 CellChangeTimes->{3.9855438790496902`*^9, 3.985546895771686*^9},
 CellLabel->"Out[70]=",ExpressionUUID->"96748007-ee37-4915-899a-e03902212a4e"],

Cell[BoxData[
 RowBox[{"50", " ", 
  RowBox[{"Sin", "[", 
   RowBox[{"0.2000001999999`", " ", "t"}], "]"}]}]], "Output",
 CellChangeTimes->{3.9855438790496902`*^9, 3.985546895772003*^9},
 CellLabel->"Out[71]=",ExpressionUUID->"fea06421-0f6a-4b94-80e9-79f37cad68f8"]
}, Open  ]],

Cell["\<\
Here are the equations describing the moon\[CloseCurlyQuote]s x- and \
y-coordinates (with the planet at the center of the orbit):\
\>", "Text",
 CellChangeTimes->{{3.985447623070346*^9, 
  3.985447639728985*^9}},ExpressionUUID->"d2bc3154-9bba-400d-ae76-\
1a37d9177279"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x3", "[", "t_", "]"}], "=", 
  RowBox[{"0.1", "*", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", "*", "Pi", "*", "f3", "*", "t"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y3", "[", "t_", "]"}], "=", 
  RowBox[{
   RowBox[{"-", "0.1"}], "*", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "*", "Pi", "*", "f3", "*", "t"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.985447644521015*^9, 3.985447662911768*^9}, {
  3.985447701120762*^9, 3.9854477020415297`*^9}},
 CellLabel->"In[72]:=",ExpressionUUID->"76627374-7112-4e2f-bd4b-33fb4420db5a"],

Cell[BoxData[
 RowBox[{"0.1`", " ", 
  RowBox[{"Cos", "[", 
   RowBox[{"3.1937438845342623`", " ", "t"}], "]"}]}]], "Output",
 CellChangeTimes->{3.985543879057176*^9, 3.985546895776375*^9},
 CellLabel->"Out[72]=",ExpressionUUID->"ff05d914-1875-4f89-8dc1-38b412c95980"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "0.1`"}], " ", 
  RowBox[{"Sin", "[", 
   RowBox[{"3.1937438845342623`", " ", "t"}], "]"}]}]], "Output",
 CellChangeTimes->{3.985543879057176*^9, 3.9855468957766867`*^9},
 CellLabel->"Out[73]=",ExpressionUUID->"58877d9c-2bf1-4016-befb-213627e33923"]
}, Open  ]],

Cell["\<\
We  can also define these equations to be relative to the star\
\[CloseCurlyQuote]s position:\
\>", "Text",
 CellChangeTimes->{{3.9854476779102097`*^9, 
  3.985447717581806*^9}},ExpressionUUID->"536e7b1a-604d-4e64-9f65-\
69ac1a602dbe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x23", "[", "t_", "]"}], "=", 
  RowBox[{
   RowBox[{"x2", "[", "t", "]"}], "+", 
   RowBox[{"x3", "[", "t", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y23", "[", "t_", "]"}], "=", 
  RowBox[{
   RowBox[{"y2", "[", "t", "]"}], "+", 
   RowBox[{"y3", "[", "t", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.985447705400277*^9, 3.985447752996467*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"537d56cd-ad8a-4dac-b9c9-9fb37569914d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"50", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"0.2000001999999`", " ", "t"}], "]"}]}], "+", 
  RowBox[{"0.1`", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"3.1937438845342623`", " ", "t"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.985543879059806*^9, 3.9855468957783623`*^9},
 CellLabel->"Out[74]=",ExpressionUUID->"21aae8c1-bb35-405a-bb5b-135d3fc033d7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"50", " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"0.2000001999999`", " ", "t"}], "]"}]}], "-", 
  RowBox[{"0.1`", " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"3.1937438845342623`", " ", "t"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.985543879059806*^9, 3.98554689577868*^9},
 CellLabel->"Out[75]=",ExpressionUUID->"9ff979a8-02f6-4f37-bcdd-d8770a126d21"]
}, Open  ]],

Cell["\<\
Let\[CloseCurlyQuote]s define the following variables: \[OpenCurlyQuote]a\
\[CloseCurlyQuote] is the semi-major axis of the orbit which we\
\[CloseCurlyQuote]ll assume is the radius of a perfectly circular orbit, \
\[OpenCurlyQuote]G\[CloseCurlyQuote] is the gravitational constant, \
\[OpenCurlyQuote]M\[CloseCurlyQuote] is the mass of the larger body, \
\[OpenCurlyQuote]m\[CloseCurlyQuote] is the mass of the smaller body. Now for \
the general equations of the coordinates of a body in orbit around another \
body with significantly more mass. Let\[CloseCurlyQuote]s assume that the \
smaller body\[CloseCurlyQuote]s position starts with a positive x-coordinate \
and no y-coordinate so we can simplify the functions into cosine and sine. \
Here are the general formulae:\
\>", "Text",
 CellChangeTimes->{{3.985447779295191*^9, 3.98544783585819*^9}, {
  3.9854479058417673`*^9, 3.9854480833516407`*^9}, {3.985448171732008*^9, 
  3.985448193458009*^9}, {3.985448243517748*^9, 
  3.985448246358773*^9}},ExpressionUUID->"26af5555-b153-4164-9a2f-\
7d7220ffa4a5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"T", "=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"4", "*", 
    RowBox[{"Pi", "^", "2"}], "*", 
    RowBox[{
     RowBox[{"a", "^", "3"}], "/", 
     RowBox[{"(", 
      RowBox[{"G", "*", 
       RowBox[{"(", 
        RowBox[{"M", "+", "m"}], ")"}]}], ")"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "=", 
   RowBox[{"1", "/", "T"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "[", "t_", "]"}], "=", 
  RowBox[{"a", "*", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", "*", "Pi", "*", "f", "*", "t"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "[", "t_", "]"}], "=", 
  RowBox[{"a", "*", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", "*", "Pi", "*", "f", "*", "t"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.985447838504278*^9, 3.9854479039591007`*^9}, {
  3.985448093355812*^9, 3.985448123787237*^9}, {3.985448155683124*^9, 
  3.9854481693773203`*^9}, {3.9854482175947037`*^9, 3.985448218194928*^9}},
 CellLabel->"In[76]:=",ExpressionUUID->"49f5f6bf-9994-4fef-9194-ff79dc4a8e6c"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "5"], " ", 
  SqrtBox[
   FractionBox[
    SuperscriptBox["a", "3"], 
    RowBox[{"m", "+", "M"}]]], " ", "\[Pi]"}]], "Output",
 CellChangeTimes->{3.985543879069641*^9, 3.985546895780443*^9},
 CellLabel->"Out[76]=",ExpressionUUID->"9ed19ca5-5586-46d6-b609-a620c16d53c0"],

Cell[BoxData[
 FractionBox["5", 
  RowBox[{
   SqrtBox[
    FractionBox[
     SuperscriptBox["a", "3"], 
     RowBox[{"m", "+", "M"}]]], " ", "\[Pi]"}]]], "Output",
 CellChangeTimes->{3.985543879069641*^9, 3.985546895780767*^9},
 CellLabel->"Out[77]=",ExpressionUUID->"2c8b7499-bd69-4c63-b10e-e2237ad348e8"],

Cell[BoxData[
 RowBox[{"a", " ", 
  RowBox[{"Cos", "[", 
   FractionBox[
    RowBox[{"10", " ", "t"}], 
    SqrtBox[
     FractionBox[
      SuperscriptBox["a", "3"], 
      RowBox[{"m", "+", "M"}]]]], "]"}]}]], "Output",
 CellChangeTimes->{3.985543879069641*^9, 3.985546895781102*^9},
 CellLabel->"Out[78]=",ExpressionUUID->"a3afc4a3-5ab0-4785-96a7-687856cd7336"],

Cell[BoxData[
 RowBox[{"a", " ", 
  RowBox[{"Sin", "[", 
   FractionBox[
    RowBox[{"10", " ", "t"}], 
    SqrtBox[
     FractionBox[
      SuperscriptBox["a", "3"], 
      RowBox[{"m", "+", "M"}]]]], "]"}]}]], "Output",
 CellChangeTimes->{3.985543879069641*^9, 3.985546895781417*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"2079446c-8086-4595-8595-ddee2d2003ae"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Part 8 - Animation", "Section",
 CellChangeTimes->{{3.9854474817014227`*^9, 3.985447498834977*^9}, {
  3.9855443186711597`*^9, 
  3.985544326659634*^9}},ExpressionUUID->"a03f0eaa-14b4-40eb-a9ac-\
01124e09a4bd"],

Cell["\<\
Graphs are great, but let\[CloseCurlyQuote]s see if we can get a better idea \
of this motion with an animation\
\>", "Text",
 CellChangeTimes->{{3.985447545524*^9, 3.985447582346176*^9}, {
  3.9855443299483347`*^9, 
  3.9855443518913593`*^9}},ExpressionUUID->"09414c37-4773-452a-b81f-\
995991b6b1c7"],

Cell["\<\
We\[CloseCurlyQuote]ll start by making the x and y components of the motions \
of the bodies into lists:\
\>", "Text",
 CellChangeTimes->{{3.985544427778912*^9, 
  3.985544461241149*^9}},ExpressionUUID->"1f4cf95a-9594-46a3-a0e7-\
93d944c8ea4f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"StarPosition", "=", 
   RowBox[{"{", "r1i", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"StarMotion", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlanetPosition", "=", 
   RowBox[{"{", "r2i", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PlanetMotion", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Moonposition", "=", 
   RowBox[{"{", 
    RowBox[{"r3i", "+", "r2i"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MoonMotion", "=", 
   RowBox[{"{", "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.985544464937063*^9, 3.9855444958479567`*^9}, {
  3.9855445284097643`*^9, 3.985544575049011*^9}, {3.9855446336567698`*^9, 
  3.985544658276743*^9}, {3.985544740241185*^9, 3.9855447490554447`*^9}, {
  3.985544952895825*^9, 3.985544953178608*^9}, {3.985547266629339*^9, 
  3.985547269705187*^9}},
 CellLabel->
  "In[114]:=",ExpressionUUID->"e830013a-c486-4357-b6de-d72df109912b"],

Cell["\<\
Now we\[CloseCurlyQuote]ll define a function that will update these lists \
incrementally for a given time.\
\>", "Text",
 CellChangeTimes->{{3.985545272971352*^9, 
  3.985545337491047*^9}},ExpressionUUID->"3cc2b173-1ff6-49e3-8770-\
8d8cb783af9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"orbit", "[", "tmax_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"time", "=", "0."}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"time", "<=", "tmax"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"time", "+=", ".05"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"update", " ", "star"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"StarPosition", "=", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x1sol", "/.", 
             RowBox[{"t", "->", "time"}]}], ",", 
            RowBox[{"y1sol", "/.", 
             RowBox[{"t", "->", "time"}]}]}], "}"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"StarMotion", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x1sol", "/.", 
             RowBox[{"t", "->", "time"}]}], ",", 
            RowBox[{"y1sol", "/.", 
             RowBox[{"t", "->", "time"}]}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"update", " ", "planet"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"PlanetPosition", "=", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x2sol", "/.", 
             RowBox[{"t", "->", "time"}]}], ",", 
            RowBox[{"y2sol", "/.", 
             RowBox[{"t", "->", "time"}]}]}], "}"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"PlanetMotion", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x2sol", "/.", 
             RowBox[{"t", "->", "time"}]}], ",", 
            RowBox[{"y2sol", "/.", 
             RowBox[{"t", "->", "time"}]}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"update", " ", "moon"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Moonposition", "=", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x3sol", "/.", 
             RowBox[{"t", "->", "time"}]}], ",", 
            RowBox[{"y3sol", "/.", 
             RowBox[{"t", "->", "time"}]}]}], "}"}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"MoonMotion", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x3sol", "/.", 
             RowBox[{"t", "->", "time"}]}], ",", 
            RowBox[{"y3sol", "/.", 
             RowBox[{"t", "->", "time"}]}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Pause", "[", ".05", "]"}]}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"(*", "reset", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"StarPosition", "=", 
      RowBox[{"{", "r1i", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"StarMotion", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"PlanetPosition", "=", 
      RowBox[{"{", "r2i", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"PlanetMotion", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Moonposition", "=", 
      RowBox[{"{", 
       RowBox[{"r3i", "+", "r2i"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"MoonMotion", "=", 
      RowBox[{"{", "}"}]}], ";"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",\

 CellChangeTimes->{{3.985544988223339*^9, 3.985544996623486*^9}, {
  3.985545040758872*^9, 3.985545259006394*^9}, {3.985545968331811*^9, 
  3.9855460222399387`*^9}, {3.985546192450376*^9, 3.985546262341263*^9}, {
  3.985546292376855*^9, 3.985546305770421*^9}, {3.9855463844970512`*^9, 
  3.985546385328822*^9}, {3.985546422843552*^9, 3.98554642546384*^9}, {
  3.985546484476766*^9, 3.9855464956642847`*^9}, {3.985546863944201*^9, 
  3.985547044989451*^9}, {3.985547075752046*^9, 3.985547076029607*^9}, {
  3.985547107715754*^9, 3.9855471331920652`*^9}, {3.98554719182036*^9, 
  3.9855472160552063`*^9}, {3.9855472745780687`*^9, 3.985547277125955*^9}, {
  3.985547367761346*^9, 3.985547380124365*^9}, {3.98554751691255*^9, 
  3.985547524745027*^9}},
 CellLabel->
  "In[121]:=",ExpressionUUID->"35be4629-8200-45ea-9ede-df2d39a10d15"],

Cell["\<\
Now we\[CloseCurlyQuote]ll make a control for us to control how long the \
animation runs (which will be initially set to the period of the planet) as \
well as for the range of the field of view and write the code for the \
animation:\
