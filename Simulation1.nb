Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"T2", "=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"4", "*", 
    RowBox[{"Pi", "^", "2"}], "*", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Norm", "[", "r2i", "]"}], ")"}], "^", "3"}], "/", 
     RowBox[{"(", 
      RowBox[{"G", "*", 
       RowBox[{"(", 
        RowBox[{"m1", "+", "m2"}], ")"}]}], ")"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"T3", "=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"4", "*", 
    RowBox[{"Pi", "^", "2"}], "*", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Norm", "[", "r3i", "]"}], ")"}], "^", "3"}], "/", 
     RowBox[{"(", 
      RowBox[{"G", "*", 
       RowBox[{"(", 
        RowBox[{"m2", "+", "m3"}], ")"}]}], ")"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.985446491137845*^9, 3.9854465058266687`*^9}, {
  3.985446556680965*^9, 3.985446569612814*^9}, {3.985446612266474*^9, 
  3.98544661577141*^9}, {3.985448128385511*^9, 3.985448129026142*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"ffd331e1-01fc-4751-a496-d9885ddfcbe0"],

