Cell["\<\
Alright, it looks pretty  close. There\[CloseCurlyQuote]s just a slight \
computational error. Now let\[CloseCurlyQuote]s do the \
moon\[CloseCurlyQuote]s orbital motion. The moon\[CloseCurlyQuote]s orbital \
motion around the planet starts off with a negative y-velocity relative to \
the planet, so we\[CloseCurlyQuote]ll have to add a negative sine wave for \
the y-component of the moon\[CloseCurlyQuote]s orbital path.\
\>", "Text",
 CellChangeTimes->{{3.985446993749488*^9, 3.985447017016881*^9}, {
  3.9854471791387167`*^9, 3.985447179487887*^9}, {3.9854472161819696`*^9, 
  3.985447229213174*^9}},ExpressionUUID->"1f4f6b49-c9ac-4115-96c0-\
cca5e409458a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f3", "=", 
   RowBox[{"1", "/", "T3"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x3sol", "-", "x2sol"}], ",", 
     RowBox[{"0.1", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "*", "Pi", "*", "f3", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"y3sol", "-", "y2sol"}], ",", 
     RowBox[{
      RowBox[{"-", "0.1"}], 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "*", "Pi", "*", "f3", "*", "t"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", "Thick"}], ",", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.985446951372114*^9, 3.985446976949862*^9}, {
  3.985447030077059*^9, 3.985447033907309*^9}, {3.98544707613702*^9, 
  3.985447120742104*^9}, {3.985447208311162*^9, 3.985447246614811*^9}},
 CellLabel->"In[67]:=",ExpressionUUID->"9cc7ee09-abbb-4545-b10d-788528c3522e"],

