70d84a183286"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"solution", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x1", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc1", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y1", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc1", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x2", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc2", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y2", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc2", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x3", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc3", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y3", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc3", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x1", "[", "0", "]"}], "==", 
         RowBox[{"r1i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y1", "[", "0", "]"}], "==", 
         RowBox[{"r1i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x2", "[", "0", "]"}], "==", 
         RowBox[{"r2i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y2", "[", "0", "]"}], "==", 
         RowBox[{"r2i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x3", "[", "0", "]"}], "==", 
         RowBox[{
          RowBox[{"r2i", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{"r3i", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"y3", "[", "0", "]"}], "==", 
         RowBox[{
          RowBox[{"r2i", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "+", 
          RowBox[{"r3i", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x1", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v1i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y1", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v1i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x2", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v2i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y2", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v2i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x3", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v3i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y3", "'"}], "[", "0", "]"}], "==", 
         RowBox[{"v3i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x1", "[", "t", "]"}], ",", 
        RowBox[{"y1", "[", "t", "]"}], ",", 
        RowBox[{"x2", "[", "t", "]"}], ",", 
        RowBox[{"y2", "[", "t", "]"}], ",", 
        RowBox[{"x3", "[", "t", "]"}], ",", 
        RowBox[{"y3", "[", "t", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "100"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
