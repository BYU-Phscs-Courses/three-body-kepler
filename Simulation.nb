Cell[CellGroupData[{

Cell["Part 3 - Setting Up the Initial Acc. and Velocities", "Section",
 CellChangeTimes->{{3.985199329443369*^9, 3.9851993344111977`*^9}, {
  3.985199371010097*^9, 3.9851993806438913`*^9}, {3.985200767441592*^9, 
  3.9852007685889463`*^9}},ExpressionUUID->"6804b142-4091-440b-9a4e-\
0c7707742f98"],

Cell["\<\
We\[CloseCurlyQuote]ll use the concepts of tangential velocity and \
centripetal acceleration to find the initial velocities needed to keep them \
in circular orbits and the initial accelerations that make them go in orbit \
in the first place. The acceleration functions defined above represent the \
second time derivatives of the position functions of each celestial body.\
\>", "Text",
 CellChangeTimes->{{3.985199421838668*^9, 3.985199428765232*^9}, {
  3.98519953425289*^9, 3.985199536789464*^9}, {3.985199670782579*^9, 
  3.985199703582176*^9}, {3.985199737595498*^9, 3.985199753532929*^9}, {
  3.985200129484457*^9, 3.985200139030982*^9}, {3.985200292543879*^9, 
  3.9852003131886473`*^9}, {3.985200775250285*^9, 
  3.985200801037986*^9}},ExpressionUUID->"872d2b39-aad7-4aef-bcb9-\
0f0933c72e11"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"acc1i", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"acc2i", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m1", "*", 
      RowBox[{
       RowBox[{"r2i", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "/", 
       RowBox[{
        RowBox[{"Norm", "[", "r2i", "]"}], "^", "2"}]}]}], ",", 
     RowBox[{"G", "*", "m1", "*", 
      RowBox[{
       RowBox[{"r3i", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "/", 
       RowBox[{
        RowBox[{"Norm", "[", "r3i", "]"}], "^", "2"}]}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"acc3i", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"G", "*", "m2", "*", 
       RowBox[{
        RowBox[{"r3i", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "/", 
        RowBox[{
         RowBox[{"Norm", "[", "r3i", "]"}], "^", "2"}]}]}], ",", 
      RowBox[{"G", "*", "m2", "*", 
       RowBox[{
        RowBox[{"r3i", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "/", 
        RowBox[{
         RowBox[{"Norm", "[", "r3i", "]"}], "^", "2"}]}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v1i", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v2i", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"r2i", "*", "acc2i"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"v3i", "=", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"r3i", "*", "acc3i"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"v1i", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"v2i", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"v3i", "//", "MatrixForm"}]}], "Input",
