Cell[CellGroupData[{
Cell["Part 1 - Defining the Variables", "Section",
 CellChangeTimes->{{3.985091030280538*^9, 3.985091125689316*^9}, {
  3.9850911798462257`*^9, 3.985091208687347*^9}, {3.985091246828575*^9, 
  3.985091281776403*^9}, {3.9850967682822123`*^9, 
  3.98509677545953*^9}},ExpressionUUID->"e6d63926-5f1e-4520-9346-\
d9fb04812268"],

Cell["\<\
First, we start off the defining the gravitational constant, G, the masses of \
the star, planet, and moon, and their respective distance from their orbital \
parents. We\[CloseCurlyQuote]ll use SI units for now but also set G=1 for \
simplicity. Later on, however, we\[CloseCurlyQuote]ll use a more realistic \
gravitational constant. The masses of the star, planet, and moon, \
respectively, are m1, m2, and m3 and their respective orbital distances from \
their orbital parents are r1, r2, and r3 (the star\[CloseCurlyQuote]s orbital \
distance is 0 because it\[CloseCurlyQuote]s the most massive body in the \
system).\
\>", "Text",
 CellChangeTimes->{
  3.985096762345228*^9, {3.985200351764724*^9, 
   3.9852003564304333`*^9}},ExpressionUUID->"8958cceb-b112-4462-a5de-\
ef394789f4a8"],

