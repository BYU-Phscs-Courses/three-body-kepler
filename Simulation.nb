Cell[CellGroupData[{

Cell["Part 4 - Solving the Differential Equation", "Section",
 CellChangeTimes->{{3.9852011858939457`*^9, 3.9852012093087673`*^9}, {
  3.98520185226001*^9, 
  3.985201857882745*^9}},ExpressionUUID->"50d43ad7-4df8-4c4f-858a-\
ac5bbc523315"],

Cell["\<\
Now we\[CloseCurlyQuote]ll set the initial conditions and get ready to solve \
these differential equations.\
\>", "Text",
 CellChangeTimes->{{3.985201491003364*^9, 3.985201505848353*^9}, {
  3.985273456227173*^9, 
  3.985273456853709*^9}},ExpressionUUID->"84b9320c-3f24-4182-a11e-\
70d84a183286"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"solution", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x1", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
