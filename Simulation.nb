           RowBox[{"r2", "[", "t", "]"}], "-", 
           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}]}], 
    "}"}], "+", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m3", "*", 
