         RowBox[{"x2", "[", "t", "]"}], "-", 
         RowBox[{"x1", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r2", "[", "t", "]"}], "-", 
           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}], ",", 
     RowBox[{"G", "*", "m1", "*", "m2", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"y2", "[", "t", "]"}], "-", 
         RowBox[{"y1", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r2", "[", "t", "]"}], "-", 
           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}]}], 
    "}"}], "+", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m1", "*", "m3", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x3", "[", "t", "]"}], "-", 
         RowBox[{"x1", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r3", "[", "t", "]"}], "-", 
           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}], ",", 
     RowBox[{"G", "*", "m1", "*", "m3", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"y3", "[", "t", "]"}], "-", 
         RowBox[{"y1", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r3", "[", "t", "]"}], "-", 
           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}]}], 
    "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"acc2", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m2", "*", "m1", "*", 
