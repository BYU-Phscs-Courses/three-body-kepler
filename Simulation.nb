   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m3", "*", "m2", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x2", "[", "t", "]"}], "-", 
         RowBox[{"x3", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
