         RowBox[{
          RowBox[{"y2", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc2", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x3", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc3", "[", "t", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y3", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          RowBox[{"acc3", "[", "t", "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"x1", "[", "0", "]"}], "==", 
         RowBox[{"r1i", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"y1", "[", "0", "]"}], "==", 
         RowBox[{"r1i", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", 
        RowBox[{
