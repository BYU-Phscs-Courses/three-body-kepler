       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r2", "[", "t", "]"}], "-", 
           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}], ",", 
     RowBox[{"G", "*", "m2", "*", 
      RowBox[{
       RowBox[{"(", 
