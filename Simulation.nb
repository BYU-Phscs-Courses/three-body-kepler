       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r1", "[", "t", "]"}], "-", 
           RowBox[{"r2", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}], ",", 
     RowBox[{"G", "*", "m2", "*", "m1", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"y1", "[", "t", "]"}], "-", 
         RowBox[{"y2", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r1", "[", "t", "]"}], "-", 
           RowBox[{"r2", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}]}], 
    "}"}], "+", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m2", "*", "m3", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x3", "[", "t", "]"}], "-", 
         RowBox[{"x2", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r3", "[", "t", "]"}], "-", 
           RowBox[{"r2", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}], ",", 
     RowBox[{"G", "*", "m2", "*", "m3", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"y3", "[", "t", "]"}], "-", 
         RowBox[{"y2", "[", "t", "]"}]}], ")"}], "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"r3", "[", "t", "]"}], "-", 
