           RowBox[{"r1", "[", "t", "]"}]}], "]"}], ")"}], "^", "2"}]}]}]}], 
    "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"acc2", "[", "t_", "]"}], ":=", 
  RowBox[{
