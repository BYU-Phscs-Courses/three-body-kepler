b06e9a0bcbcf"],

Cell["\<\
Now let\[CloseCurlyQuote]s define the differential equations based on both \
Newtonian mechanics and Kepler\[CloseCurlyQuote]s laws of planetary motion.\
\>", "Text",
 CellChangeTimes->{{3.985096864418317*^9, 
  3.985096911769046*^9}},ExpressionUUID->"23fb1e19-7849-404f-a3c5-\
21a8c3d4896e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"r1", "[", "t_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x1", "[", "t", "]"}], ",", 
    RowBox[{"y1", "[", "t", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r2", "[", "t_", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x2", "[", "t", "]"}], ",", 
    RowBox[{"y2", "[", "t", "]"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"r3", "[", "t_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x3", "[", "t", "]"}], ",", 
     RowBox[{"y3", "[", "t", "]"}]}], "}"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"acc1", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "*", "m1", "*", "m2", "*", 
      RowBox[{
       RowBox[{"(", 
